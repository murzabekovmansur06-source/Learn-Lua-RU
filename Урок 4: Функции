-- Факториал
local function factorial(n)
    local result = 1
    for i = 1, n do
        result = result * i
    end
    return result
end
print("Факториал 5 = " .. factorial(5))
print("Факториал 10 = " .. factorial(10))
print("")

-- Статус по здоровью
local function getStatus(health)
    if health > 50 then
        return "Отлично"
    elseif health > 25 then
        return "Средне"
    elseif health > 0 then
        return "Плохо"
    else
        return "Мёртв"
    end
end
print("Здоровье 100: " .. getStatus(100))
print("Здоровье 30: " .. getStatus(30))
print("Здоровье 10: " .. getStatus(10))
print("Здоровье 0: " .. getStatus(0))
print("")

-- Цельсий в Фаренгейт
local function celsiusToFahrenheit(c)
    return c * 9 / 5 + 32
end
print("0°C = " .. celsiusToFahrenheit(0) .. "°F")
print("100°C = " .. celsiusToFahrenheit(100) .. "°F")
print("25°C = " .. celsiusToFahrenheit(25) .. "°F")

