## Прокручиваемая область (ScrollingFrame)

Полезно для длинных списков (инвентарь, чат):

local scrollFrame = Instance.new("ScrollingFrame")
scrollFrame.Size = UDim2.new(0, 300, 0, 400)
scrollFrame.Position = UDim2.new(0.5, -150, 0.5, -200)
scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 800)  -- высота содержимого
scrollFrame.ScrollBarThickness = 5
scrollFrame.Parent = gui

-- Добавляем элементы внутрь
for i = 1, 20 do
    local item = Instance.new("TextLabel")
    item.Size = UDim2.new(1, -10, 0, 30)
    item.Position = UDim2.new(0, 5, 0, (i-1) * 35)
    item.Text = "Предмет " .. i
    item.Parent = scrollFrame
end

## Красивые кнопки

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 200, 0, 50)
button.Position = UDim2.new(0.5, -100, 0.5, -25)
button.Text = "Кнопка"
button.BackgroundColor3 = Color3.fromRGB(0, 150, 255)  -- синий
button.TextColor3 = Color3.fromRGB(255, 255, 255)  -- белый текст
button.Font = Enum.Font.GothamBold
button.TextSize = 18
button.Parent = gui

-- Скругление углов
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 10)  -- радиус 10 пикселей
corner.Parent = button

-- Обводка
local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(255, 255, 255)
stroke.Thickness = 2
stroke.Parent = button

-- Эффект при наведении
button.MouseEnter:Connect(function()
    button.BackgroundColor3 = Color3.fromRGB(0, 200, 255)  -- светлее
end)

button.MouseLeave:Connect(function()
    button.BackgroundColor3 = Color3.fromRGB(0, 150, 255)  -- обратно
end)

