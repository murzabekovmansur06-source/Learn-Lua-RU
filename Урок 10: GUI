# Урок 10: GUI — интерфейс для игрока

## Что такое GUI?

GUI (Graphical User Interface) — это всё что игрок видит на экране кроме игрового мира: кнопки, меню, полоски здоровья, инвентарь, чат.

GUI создаётся через LocalScript в StarterGui. У каждого игрока свой GUI, и он видит только свой.

## Главные элементы GUI

ScreenGui — контейнер для всего GUI (как лист бумаги)
Frame — прямоугольная область (как коробка)
TextLabel — текст
TextButton — кнопка с текстом
ImageLabel — картинка
TextBox — поле для ввода текста
ScrollingFrame — прокручиваемая область

## Создание простого GUI

В StarterGui создай LocalScript:

-- Создаём контейнер
local gui = Instance.new("ScreenGui")
gui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")

-- Создаём кнопку
local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 200, 0, 50)   -- ширина 200, высота 50
button.Position = UDim2.new(0.5, -100, 0.5, -25)  -- по центру
button.Text = "Нажми меня!"
button.Parent = gui

-- Обработчик нажатия
button.MouseButton1Click:Connect(function()
    print("Кнопка нажата!")
end)

## UDim2 — позиция и размер

UDim2.new(scaleX, offsetX, scaleY, offsetY)

scale — доля экрана (0 = слева/сверху, 1 = справа/снизу)
offset — пиксели

Примеры:

-- По центру экрана
UDim2.new(0.5, -100, 0.5, -25)  -- половина экрана минус половина ширины

-- В левом верхнем углу
UDim2.new(0, 10, 0, 10)  -- 10 пикселей от левого края, 10 от верхнего

-- На весь экран
UDim2.new(1, 0, 1, 0)

-- Внизу по центру
UDim2.new(0.5, -100, 1, -60)  -- половина ширины, снизу 60 пикселей

## Текст (TextLabel)

local label = Instance.new("TextLabel")
label.Size = UDim2.new(0, 300, 0, 30)
label.Position = UDim2.new(0.5, -150, 0.1, 0)
label.Text = "Добро пожаловать!"
label.TextColor3 = Color3.fromRGB(255, 255, 255)  -- белый
label.TextSize = 24  -- размер шрифта
label.Font = Enum.Font.GothamBold  -- жирный шрифт
label.BackgroundTransparency = 1  -- прозрачный фон
label.Parent = gui

## Изменение текста из скрипта

local coins = 0
local label = Instance.new("TextLabel")
label.Parent = gui
-- ... настройки ...

button.MouseButton1Click:Connect(function()
    coins = coins + 1
    label.Text = "Монет: " .. coins
end)

## Полоска здоровья (Frame)

local healthBar = Instance.new("Frame")
healthBar.Size = UDim2.new(0, 200, 0, 20)
healthBar.Position = UDim2.new(0, 10, 0, 10)
healthBar.BackgroundColor3 = Color3.fromRGB(255, 0, 0)  -- красный
healthBar.Parent = gui

-- Меняем размер при получении урона
local health = 100
healthBar.Size = UDim2.new(health / 100, 0, 0, 20)  -- пропорционально здоровью

## Поле ввода (TextBox)

local textBox = Instance.new("TextBox")
textBox.Size = UDim2.new(0, 200, 0, 30)
textBox.Position = UDim2.new(0.5, -100, 0.5, 0)
textBox.PlaceholderText = "Введи что-нибудь..."
textBox.Text = ""
textBox.Parent = gui

-- Когда игрок нажимает Enter
textBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        print("Игрок ввёл: " .. textBox.Text)
    end
end)

