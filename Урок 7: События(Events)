end)

-- Создаём кнопку телепортации
local button = Instance.new("Part")
button.Position = Vector3.new(10, 3, 0)
button.Size = Vector3.new(3, 1, 3)
button.Anchored = true
button.Color = Color3.fromRGB(0, 255, 0)
