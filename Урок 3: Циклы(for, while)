Скопируй в Roblox Studio:

-- Урок 3: Циклы

print("========== УРОК 3: ЦИКЛЫ ==========")
print("")

-- Простой for
print("Счёт от 1 до 5:")
for i = 1, 5 do
    print(i)
end
print("")

-- Шаг 2
print("Чётные от 0 до 10:")
for i = 0, 10, 2 do
    print(i)
end
print("")

-- Обратный отсчёт
print("Обратный отсчёт:")
for i = 3, 1, -1 do
    print(i)
end
print("Пуск!")
print("")

-- Сумма
print("Сумма от 1 до 10:")
local sum = 0
for i = 1, 10 do
    sum = sum + i
end
print(sum)
print("")

-- Факториал
print("Факториал 5:")
local fact = 1
for i = 1, 5 do
    fact = fact * i
end
print(fact)
print("")

-- while
print("while цикл:")
local coins = 10
while coins > 0 do
    print("Монет: " .. coins)
    coins = coins - 3
end
print("Монеты кончились!")
print("")

-- Вложенные циклы
print("Вложенные циклы:")
for i = 1, 3 do
    for j = 1, 2 do
        print(i .. " и " .. j)
    end
end
print("")

-- break
print("break:")
for i = 1, 10 do
    if i == 4 then
        print("Стоп!")
        break
    end
    print(i)
end
print("")

-- Делимость на 3 и 5
print("Числа от 1 до 20 (делимость):")
for i = 1, 20 do
    if i % 3 == 0 and i % 5 == 0 then
        print(i .. " — на 3 и 5")
    elseif i % 3 == 0 then
        print(i .. " — на 3")
    elseif i % 5 == 0 then
        print(i .. " — на 5")
    else
        print(i)
    end
end

print("")
print("========== КОНЕЦ УРОКА 3 ==========")
